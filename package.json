{
  "name": "droid-crash-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Local Android crash reproduction laboratory",
  "type": "module",
  "main": "dist/electron/main.js",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "build": "npm run build:web && npm run build:server && npm run build:electron",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "node dist/server/index.js",
    "desktop": "npm run build && electron .",
    "package:mac": "npm run build && electron-builder --mac dmg zip",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.server-test.json --noEmit && tsc -p tsconfig.web.json --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.tools.json --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:electron": "npm run build && playwright test --config playwright.electron.config.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^10.1.0",
    "archiver": "^8.0.0",
    "fastify": "^5.10.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^8.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "xyz.020688.droid-crash-lab",
    "productName": "DroidCrashLab",
    "asar": true,
    "files": [
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "mac": {
      "identity": null,
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
