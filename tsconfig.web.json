{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client", "vitest/globals"],
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src/web/**/*.ts",
    "src/web/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
